---
layout: base.njk
---


<article class="project-post">

  <section class="column-left" aria-label="Left column - project details">
    <div class="column-left-inner">




      <div class="project-meta">
        <a class="back" href="/projects/"><span aria-hidden="true" class="arrow-back">&larr;</span> Back to all
          projects</a>

      </div>


      <h1>{{ project.title }}</h1>




      {% if project.tags %}
      {% for tag in project.tags %}
      {% if tag == "Case Study" %}
      <span class="tag tag--case">Case study</span>&ensp;
      {% endif %}
      {% if tag == "WIP" %}
      <span class="tag tag--wip">WIP</span>&ensp;
      {% endif %}
      {% endfor %}
      {% endif %}


      {% set filteredTags = project.tags | reject("equalto", "Case Study") | reject("equalto", "WIP") %}

      {% if project.category == "sandbox" %}
      <span class="project-categories">
        <a href="/categories/{{ project.category | slug }}/">{{ project.category }}</a>&ensp;&ensp;|&ensp;
      </span>
      {% endif %}


      {% if filteredTags.length %}
      <span class="project-tags">
        {% for tag in filteredTags %}
        <a href="/tags/{{ tag | slugify }}/">{{ tag }}</a>{% if not loop.last %}, {% endif %}
        {% endfor %}
      </span>
      {% endif %}

      <div class="leftbutton">
        {% if project.leftbuttonText and project.leftbuttonUrl %}
        <a class="button button-projects" href="{{ project.leftbuttonUrl }}" target="_blank">{{ project.leftbuttonText
          }} <span class="arrow" aria-hidden="true">→</span></a>
        {% endif %}
      </div>


      <div class="project-role">
        {% if project.role %}
        <p class="side-heading">My Role:</p>
        {{ project.role | safe }}
        {% endif %}
      </div>
      <div class="project-deliverables">
        {% if project.deliverables %}
        <p class="side-heading">Deliverables:</p>
        {{ project.deliverables | safe }}
        {% endif %}
      </div>


    </div>
  </section>

  <section class="column-right fade-in" aria-label="Project main content">
    <!-- Main content -->
    <div class="project-content">
      {% if project.content %}
      {{ project.content | safe }}
      {% else %}
      <p>Content coming soon!</p>
      {% endif %}

    </div>

    <!-- Image gallery -->
    {% if project.images and project.images.length %}
    <div class="project-gallery">
      {% for image in project.images %}
      <figure>
        <img src="{{ image.url }}" alt="{{ image.alternativeText or '' }}">
        {% if image.caption %}
        <figcaption>{{ image.caption }}</figcaption>
        {% endif %}
      </figure>
      {% endfor %}
    </div>
    {% endif %}

  </section>

</article>


{% set navProjects = projects | navProjects %}
{% set index = navProjects | findProjectIndex(project.slug) %}
{% set prev = navProjects[index - 1] or navProjects[navProjects.length - 1] %}
{% set next = navProjects[index + 1] or navProjects[0] %}

<section class="projects-more" aria-label="more-projects">
  <nav>
    {% if prev %}
    <p class="project-prev">← <br/><a href="/projects/{{ prev.slug }}/">Previous project: <br/>{{ prev.title }}</a></p>
    {% endif %}

    {% if next %}
    <p class="project-next"> →<br/><a href="/projects/{{ next.slug }}/">Next project: <br/>{{ next.title }}</a></p>

    
    {% endif %}
  </nav>
</section>