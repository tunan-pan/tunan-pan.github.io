<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Tunan Pan is a designer focused on social impact and human-centered digital experiences. View selected case studies and design work.">
  <title>Tunan Pan | Designer | {{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="manifest" href="/site.webmanifest">

  <!-- Essential Open Graph tags -->
  <meta name="title" property="og:title" content="Tunan Pan | Designer">
  <meta name="description" property="og:description" content="I'm a designer who cares about social impact & human-centered experiences.">
  <meta name="image" property="og:image" content="https://tunan.art/images/SEO-preview.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="627">
  <meta property="og:image:type" content="image/png">
  <meta name="author" content="Tunan Pan">

  <meta property="og:url" content="https://tunan.art/">
  <meta property="og:type" content="website">

  <!-- Twitter Card tags (for better Twitter display) -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Tunan Pan | Designer">
  <meta name="twitter:description" content="I'm a designer who cares about social impact & human-centered experiences.">
  <meta name="twitter:image" content="https://tunan.art/images/SEO-preview.png">
    
</head>
<body class="{% if page.url == '/about/' %}about-page{% elif page.url == '/' %}home-page{% elif page.url == '/contact/' %}contact-page{% elif page.url == '/projects/' %}projects-page{% endif %}">

  {% include 'header.njk' %}

  <main>
  {{ content | safe }}
  </main>

  <button class="back-to-top" aria-label="Back to top">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-up" viewBox="0 0 16 16">
      <path fill-rule="evenodd" d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708z"/>
    </svg>
  </button>

  {% include 'footer.njk' %}

  

  <script src="/js/mobile-menu.js"></script>

  <script src="/js/sticky-header.js"></script>
  
  <script src="/js/back-to-top.js"></script>

  <script src="/js/fade-in.js"></script>

</body>
</html>