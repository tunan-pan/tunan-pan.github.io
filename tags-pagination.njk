---
pagination:
 data: project_tags
 size: 1
 alias: project_tag

permalink: /tags/{{ project_tag | slugify }}/index.html

layout: base.njk

eleventyComputed:
 title: "Tag: {{ project_tag }}"
---

<div class="projects-intro">
  <h1>Projects Tagged: {{ project_tag }}</h1>
</div>



<div class="projects-grid projects-grid--more fade-in">

  {% for project in projects_build %}
  {# Check if the tag appears in the project's tags array #}
  {% if project.tags and project_tag in project.tags %}
  <article class="project-card project-card--small">

    <a href="/projects/{{ project.slug }}/">
        <div class="project-card__thumb">
          {% if project.image %}
          <img src="{{ project.image.url or project.image }}" alt="">
          {% endif %}
        </div>

        <div class="project-card__body">

          <div class="project-card__meta">
            {% if project.tags %}
            {% for tag in project.tags %}
            {% if tag == "Case Study" %}
            <span class="tag tag--case">Case study</span>
            {% endif %}
            {% if tag == "WIP" %}
            <span class="tag tag--wip">WIP</span>
            {% endif %}
            {% endfor %}
            {% endif %}
          </div>

          <h3>{{ project.title }}</h3>

          {% set filteredTags = project.tags | reject("equalto", "Case Study") | reject("equalto", "WIP") %}

          {% if filteredTags.length %}
          <div class="project-tags">
            <span>
              {% for tag in filteredTags %}
              {{ tag }}{% if not loop.last %}, {% endif %}
              {% endfor %}
            </span>
          </div>
          {% endif %}

        </div>

      </a>

  </article>
  {% endif %}
  {% endfor %}

</div>

<div class="back-to-projects">
  <p><a class="button button-secondary" href="/projects/"><span aria-hidden="true">&larr;</span> Back to all
      projects</a></p>
</div>